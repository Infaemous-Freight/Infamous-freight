# ------------------------------------------------------------------------------
# Core runtime
# Required in all environments
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------------------------
# Data stores
# Required when the app/service uses persistent storage or queues
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infamous_freight
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Authentication
# Required in production
# Optional for local-only mock/dev flows unless auth is exercised
# ------------------------------------------------------------------------------
JWT_SECRET=
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# ------------------------------------------------------------------------------
# Observability
# Optional locally, recommended in staging/production
# ------------------------------------------------------------------------------
SENTRY_DSN=

# ------------------------------------------------------------------------------
# Deployment
# Deployment platform secrets only; never commit real values
# ------------------------------------------------------------------------------
FLY_API_TOKEN=

# ------------------------------------------------------------------------------
# External integrations
# Optional unless the relevant integration is enabled
# ------------------------------------------------------------------------------
WEBHOOK_SECRET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
EMAIL_API_KEY=
SMS_API_KEY=
