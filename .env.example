# ============================================================
# INFAMOUS FREIGHT — Environment Variables
# Copy this file to .env and fill in your real values
# ============================================================

# ——— Database ———
DATABASE_URL=postgresql://infamous:changeme@localhost:5432/infamous_freight?schema=public
DB_USER=infamous
DB_PASSWORD=changeme
DB_NAME=infamous_freight

# ——— Redis ———
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# ——— API ———
NODE_ENV=development
PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
API_RATE_LIMIT_ENABLED=true

# ——— Rate Limits ———
# Number of requests allowed per window. Override in production as needed.
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=900
RATE_LIMIT_BILLING_MAX=10
RATE_LIMIT_BILLING_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60
RATE_LIMIT_API_WRITE_MAX=60
RATE_LIMIT_API_WRITE_WINDOW_SECONDS=60

# ——— Stripe ———
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ——— Supabase ———
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key

# ——— Load Board APIs ———
DAT_API_KEY=your-dat-api-key
TRUCKSTOP_API_KEY=your-truckstop-key
LOADBOARD_API_KEY=your-123loadboard-key

# ——— ELD Providers ———
SAMSARA_API_TOKEN=your-samsara-token
MOTIVE_CLIENT_ID=your-motive-client-id
MOTIVE_CLIENT_SECRET=your-motive-secret

# ——— QuickBooks ———
QBO_CLIENT_ID=your-qbo-client-id
QBO_CLIENT_SECRET=your-qbo-secret

# ——— Xero ———
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-secret

# ——— SendGrid ———
SENDGRID_API_KEY=SG.your-sendgrid-key
FROM_EMAIL=noreply@infamousfreight.com

# ——— Factoring ———
RTS_API_KEY=your-rts-key
OTR_API_KEY=your-otr-key
APEX_API_KEY=your-apex-key

# ——— Web Frontend ———
VITE_API_URL=http://localhost:3001
VITE_STRIPE_PUBLIC_KEY=pk_test_...
VITE_SOCKET_URL=ws://localhost:3001
