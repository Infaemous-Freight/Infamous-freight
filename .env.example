############################################################
# Infamous Freight Enterprises - Root .env.example
#
# Copy this file to `.env` and fill in the values as needed.
# This file documents all environment variables used across:
# - api/ (Express backend)
# - web/ (Next.js frontend)
# - mobile/ (Expo React Native)
# - packages/shared/ (shared types/constants/utils)
#
# NOTE:
# - Do NOT commit real secrets to version control.
# - Values here are safe defaults or placeholders.
############################################################

############################################################
# Core Service Ports
############################################################

# API service port (Express backend)
# Default: 4000 (Docker maps to 3001 internally)
API_PORT=4000

# Web (Next.js) service port
# Default: 3000
WEB_PORT=3000

# (Optional) Mobile dev server port (Expo)
# MOBILE_PORT=19000

############################################################
# Base URLs (used across web/mobile/CI)
############################################################

# Base URL where the API is accessible (without trailing slash)
# Example (local): http://localhost:4000
# Example (docker): http://localhost:3001
# Example (prod):   https://api.example.com
API_BASE_URL=http://localhost:4000

# Base URL where the web app is accessible
# Example (local): http://localhost:3000
# Example (prod):  https://app.example.com
WEB_BASE_URL=http://localhost:3000

# Vercel / production deployment URL for the web app
# Used by Next.js for absolute URLs in SSR, etc.
# Example: https://infamous-freight-enterprises.vercel.app
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000

############################################################
# Database (PostgreSQL via Prisma)
############################################################

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
# Example (local): postgres://postgres:postgres@localhost:5432/infamous_freight
DATABASE_URL=postgres://postgres:postgres@localhost:5432/infamous_freight

# Shadow DB for Prisma migrations (optional)
# SHADOW_DATABASE_URL=postgres://postgres:postgres@localhost:5432/infamous_freight_shadow

############################################################
# Authentication / JWT
############################################################

# Secret used to sign JWTs (set to a long, random string in production)
JWT_SECRET=change-me-in-production

# JWT issuer (iss claim)
JWT_ISSUER=infamous-freight-enterprises

# JWT audience (aud claim), e.g. "api" or "web"
JWT_AUDIENCE=infamous-freight-clients

# Token expiration (e.g. "15m", "1h")
JWT_EXPIRATION=1h

############################################################
# CORS & Security
############################################################

# Comma-separated list of allowed origins for CORS
# Examples:
#   http://localhost:3000
#   http://localhost:3001
#   https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Maximum voice upload size (MB) for /voice routes
# Default mentioned in docs: 10
VOICE_MAX_FILE_SIZE_MB=10

# Node environment: development | test | production
NODE_ENV=development

############################################################
# Billing / Payments (Stripe & PayPal)
############################################################

# Stripe secret key (backend only)
STRIPE_SECRET_KEY=pk_test_change_me

# Stripe publishable key (frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_change_me

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_change_me

# PayPal REST API credentials
PAYPAL_CLIENT_ID=paypal-client-id
PAYPAL_CLIENT_SECRET=paypal-client-secret

# PayPal mode: sandbox | live
PAYPAL_MODE=sandbox

############################################################
# AI Provider Configuration
############################################################

# AI provider to use in api/src/services/aiSyntheticClient.js
# Options: openai | anthropic | synthetic
# Default: synthetic (no external calls)
AI_PROVIDER=synthetic

# OpenAI configuration (used when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic configuration (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com

# Generic timeout (ms) for AI calls
AI_REQUEST_TIMEOUT_MS=15000

############################################################
# Rate Limiting (mirrors presets in security middleware)
############################################################

# General limiter: requests per 15 minutes
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_GENERAL_WINDOW_MINUTES=15

# Auth limiter: login/register requests per 15 minutes
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MINUTES=15

# AI limiter: AI commands per 1 minute
RATE_LIMIT_AI_MAX=20
RATE_LIMIT_AI_WINDOW_MINUTES=1

# Billing limiter: billing operations per 15 minutes
RATE_LIMIT_BILLING_MAX=30
RATE_LIMIT_BILLING_WINDOW_MINUTES=15

############################################################
# Redis / Caching / Queues
############################################################

# Redis connection URL
# Example: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

############################################################
# Supabase (if used for auth/storage/realtime)
############################################################

# Supabase URL & keys (frontend-safe anon key, backend service role key)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

############################################################
# Monitoring / Error Tracking / Analytics
############################################################

# Sentry DSN for backend (API)
SENTRY_DSN=

# Sentry environment: development | staging | production
SENTRY_ENVIRONMENT=development

# Datadog RUM (web) - used when NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_DD_APP_ID=
NEXT_PUBLIC_DD_CLIENT_TOKEN=
NEXT_PUBLIC_DD_SITE=datadoghq.com

# Optional: sample rate overrides
NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE=100
NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE=20

############################################################
# Logging
############################################################

# Log level for Winston logger: error | warn | info | debug
LOG_LEVEL=info

# Whether to enable pretty-printed logs in development
LOG_PRETTY_PRINT=true

############################################################
# Next.js / Web-specific config
############################################################

# Next.js public runtime environment tag (env name)
NEXT_PUBLIC_APP_ENV=development

# Public API base URL for the web app (for fetch calls)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Enable bundle analyzer when building the web app
ANALYZE=false

############################################################
# Testing / CI
############################################################

# Use a deterministic JWT secret in tests (see Jest config)
TEST_JWT_SECRET=test-secret

# Separate DB for tests (optional)
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/infamous_freight_test

############################################################
# Misc / Reserved for future use
############################################################

# Place additional env vars used by feature flags, experiments, etc. here.
# FEATURE_FLAG_EXAMPLE=false

# End of .env.example
