{
  "name": "@infamous-freight/shared",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./payments/config": {
      "types": "./dist/payments/config.d.ts",
      "default": "./dist/payments/config.js"
    },
    "./payments/types": {
      "types": "./dist/payments/types.d.ts",
      "default": "./dist/payments/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.2"
  }
}
