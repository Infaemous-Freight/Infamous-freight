{
  "name": "@infamous-freight/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/src/index.js",
  "scripts": {
    "prisma:generate": "node ./scripts/prisma-generate-if-schema.cjs",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "jest --runInBand",
    "start:dev": "tsx watch src/index.ts",
    "start:prod": "node dist/src/index.js"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.17",
    "jest": "^30.2.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "@types/supertest": "^6.0.3"
  }
}
