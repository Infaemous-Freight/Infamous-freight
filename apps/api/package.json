{
  "name": "@infamous-freight/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json && node -e \"const fs=require('fs');const candidates=['dist/server.js','dist/src/server.js'];const src=candidates.find((f)=>fs.existsSync(f));if(!src){throw new Error('Could not locate compiled server entrypoint');}fs.copyFileSync(src,'dist/main.js')\"",
    "start:dev": "tsx watch src/server.ts",
    "start:prod": "node dist/main.js",
    "test": "jest --runInBand",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.46",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^6.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.3",
    "typescript": "^5.6.3"
  }
}
