{
  "name": "@infamous-freight/api",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Infamous-Freight/Infamous-freight.git",
    "directory": "apps/api"
  },
  "type": "commonjs",
  "scripts": {
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "start:dev": "tsx watch src/server.ts",
    "start:prod": "node dist/src/server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.7.0",
    "@sentry/node": "^10.50.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "openai": "^6.35.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "6.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
