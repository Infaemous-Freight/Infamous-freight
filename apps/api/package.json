{
  "name": "@infamous-freight/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "start:dev": "tsx watch src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "node -e \"console.error('The default API test suite is still wired to the legacy Express app and does not validate the Nest runtime entrypoint (src/main.ts). Update apps/api/test to boot the Nest app and verify /api/health, then replace this guard with the new Jest command.'); process.exit(1)\"",
    "test:legacy": "jest --runInBand",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.46",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^6.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.3",
    "typescript": "^5.6.3"
  }
}
