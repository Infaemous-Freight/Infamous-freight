{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "test/**/*.ts",
    "src/**/*.spec.ts",
    "src/audit/**/*.ts",
    "src/dispatch/auto-dispatch.service.ts"
  ]
}
