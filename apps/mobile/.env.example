# Mobile App Environment Variables
# Copy this to .env and fill in your actual values

# API Configuration
EXPO_PUBLIC_API_URL=https://infamous-freight-api.fly.dev
EXPO_PUBLIC_WS_URL=wss://infamous-freight-api.fly.dev/ws

# Expo Configuration (Priority 2 - Push Notifications)
EXPO_PROJECT_ID=your-expo-project-id
EXPO_OWNER=infamous-freight

# Firebase Configuration (Get from Firebase Console → Project Settings)
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=infamous-freight-prod.firebaseapp.com
FIREBASE_PROJECT_ID=infamous-freight-prod
FIREBASE_STORAGE_BUCKET=infamous-freight-prod.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# VAPID key for web push notifications (Firebase Console → Cloud Messaging → Web Push certificates)
FIREBASE_VAPID_KEY=BNXXXXXXXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Feature Flags
ENABLE_BIOMETRIC_AUTH=true
ENABLE_OFFLINE_QUEUE=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_FIREBASE_ANALYTICS=true

# Debug
DEBUG=false
