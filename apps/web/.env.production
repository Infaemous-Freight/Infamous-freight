# Infamous Freight - Frontend Production Environment
# These values are baked into the build at compile time

# API & Services
VITE_API_URL=https://infamous-freight-api.fly.dev
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe
VITE_STRIPE_PUBLIC_KEY=REDACTED_PUBLISHABLE_KEY

# Feature Flags
VITE_ENABLE_VOICE=true
VITE_ENABLE_AUCTION=true
VITE_ENABLE_ANALYTICS=true
VITE_APP_VERSION=1.0.0
