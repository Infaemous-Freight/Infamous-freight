# Infamous Freight — Web Frontend Environment
# Leave VITE_API_URL unset (or empty) to use the Vite dev-server proxy, which
# forwards /api/* to http://localhost:3001 automatically. Set it to an absolute
# URL only when running the built app without the Vite proxy.
VITE_API_URL=
# Optional: leave unset to reuse VITE_API_URL / same-origin proxying for sockets.
# Set this only if websocket traffic must use a different absolute origin.
VITE_SOCKET_URL=
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry error monitoring (optional — omit or leave blank to disable)
# Run the Sentry setup wizard for this Vite/React app with:
#   cd apps/web && npx @sentry/wizard@latest -i react
# Note: do NOT use -i nextjs; apps/web is a Vite SPA, not a Next.js app.
VITE_SENTRY_DSN=your-sentry-dsn
# Set to "false" to disable Sentry even when a DSN is present.
# Defaults to enabled in production when DSN is set.
VITE_SENTRY_ENABLED=true
