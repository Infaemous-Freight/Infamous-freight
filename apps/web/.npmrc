engine-strict=false
ignore-scripts=true

# Netlify installs UI-managed build plugins in apps/web/.netlify/plugins.
# Some third-party plugin engine ranges lag behind the current build runtime.
# Keep strict engines at repo root, but relax it for web deploy plugin installs.
# Disable plugin lifecycle scripts there so legacy native modules (for example
# old sharp versions from stale plugins) do not try to compile during install.
