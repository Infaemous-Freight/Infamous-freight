/**
 * Bonus System Database Schema (Prisma)
 * Complete data models for bonus, loyalty, points, and referral tracking
 */

// ============================================================================
// LOYALTY TIER MODEL
// ============================================================================

model LoyaltyTier {
  id              String      @id @default(cuid())
  customerId      String      @unique
  tier            String      // 'bronze' | 'silver' | 'gold' | 'platinum'
  enrollmentDate  DateTime    @default(now())
  lastUpdated     DateTime    @updatedAt
  status          String      @default("active") // 'active' | 'suspended' | 'inactive'
  
  // Statistics
  totalPoints     Int         @default(0)
  pointsBalance   Int         @default(0)
  lifetimeSpend   Float       @default(0)
  totalShipments  Int         @default(0)
  totalReferrals  Int         @default(0)
  
  // Dates
  lastActivityDate DateTime
  nextUpgradeCheckDate DateTime
  
  // Relations
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  points          LoyaltyPoint[]
  bonuses         CustomerBonus[]
  
  @@index([tier])
  @@index([status])
}

// ============================================================================
// LOYALTY POINTS MODEL
// ============================================================================

model LoyaltyPoint {
  id              String      @id @default(cuid())
  customerId      String
  loyaltyTierId   String
  
  // Points details
  amount          Int         // Points amount
  source          String      // 'shipment' | 'purchase' | 'referral' | 'milestone' | 'bonus'
  sourceId        String?     // Reference to shipment, purchase, etc.
  pointsMultiplier Float      @default(1.0)
  
  // Expiry
  earnedDate      DateTime    @default(now())
  expiryDate      DateTime    // Auto-calculated based on tier
  
  // Status
  status          String      @default("available") // 'available' | 'redeemed' | 'expired' | 'pending'
  redeemedDate    DateTime?
  
  // Relations
  loyaltyTier     LoyaltyTier @relation(fields: [loyaltyTierId], references: [id], onDelete: Cascade)
  
  @@index([customerId])
  @@index([status])
  @@index([expiryDate])
}

// ============================================================================
// CUSTOMER BONUS MODEL
// ============================================================================

model CustomerBonus {
  id              String      @id @default(cuid())
  customerId      String
  loyaltyTierId   String
  
  // Bonus type
  type            String      // 'referral' | 'milestone' | 'performance' | 'promotional' | 'enterprise'
  bonusCode       String      @unique
  
  // Amount
  amount          Float
  currency        String      @default("USD")
  valueInPoints   Int?        // Bonus converted to points equivalent
  
  // Details
  description     String?
  reason          String?     // Why bonus was awarded
  conditions      String?     // JSON conditions for earning
  
  // Status
  status          String      @default("pending") // 'pending' | 'approved' | 'claimed' | 'expired'
  claimedDate     DateTime?
  
  // Expiry
  createdDate     DateTime    @default(now())
  expiryDate      DateTime    // When bonus expires
  
  // Relations
  loyaltyTier     LoyaltyTier @relation(fields: [loyaltyTierId], references: [id], onDelete: Cascade)
  
  @@index([customerId])
  @@index([status])
  @@index([type])
}

// ============================================================================
// REFERRAL PROGRAM MODEL
// ============================================================================

model ReferralProgram {
  id              String      @id @default(cuid())
  referrerId      String
  referralCode    String      @unique
  
  // Referral type
  type            String      // 'customer' | 'driver'
  
  // Referrer info
  referrerEmail   String
  referrerTier    String?     // Tier at time of referral
  
  // Referral info
  referredEmail   String
  referredId      String?     // Set after referred completes signup
  
  // Status
  status          String      @default("pending") // 'pending' | 'completed' | 'expired' | 'cancelled'
  
  // Bonuses
  referrerBonus   Float       @default(0)
  referredBonus   Float       @default(0)
  bonusStatus     String      @default("pending") // 'pending' | 'earned' | 'claimed' | 'forfeit'
  
  // Dates
  createdDate     DateTime    @default(now())
  completionDate  DateTime?
  expiryDate      DateTime    // Typically 365 days
  
  // Tracking
  referralUrl     String?
  clicks          Int         @default(0)
  lastClickDate   DateTime?
  
  // Relations
  referrer        Customer    @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred        Customer?   @relation("referred", fields: [referredId], references: [id], onDelete: SetNull)
  
  @@index([referrerId])
  @@index([referralCode])
  @@index([status])
  @@index([type])
}

// ============================================================================
// DRIVER PERFORMANCE BONUS MODEL
// ============================================================================

model DriverPerformance {
  id              String      @id @default(cuid())
  driverId        String      @unique
  
  // Metrics
  onTimePercentage Float      @default(0)
  averageRating   Float       @default(0)
  monthlyShipments Int        @default(0)
  totalShipments  Int         @default(0)
  accidentsFreeMonths Int     @default(0)
  referralsCount  Int         @default(0)
  
  // Bonuses
  onTimeBonus     Float       @default(0)
  ratingBonus     Float       @default(0)
  volumeBonus     Float       @default(0)
  safetyBonus     Float       @default(0)
  referralBonus   Float       @default(0)
  totalBonus      Float       @default(0)
  
  // Dates
  lastUpdated     DateTime    @updatedAt
  bonusPeriod     String      // 'monthly' | 'quarterly' | 'annual'
  periodStart     DateTime
  periodEnd       DateTime
  
  // Status
  bonusStatus     String      @default("pending") // 'pending' | 'approved' | 'paid'
  
  @@index([driverId])
  @@index([bonusStatus])
}

// ============================================================================
// MILESTONE ACHIEVEMENT MODEL
// ============================================================================

model MilestoneAchievement {
  id              String      @id @default(cuid())
  customerId      String
  
  // Milestone type
  type            String      // 'shipment' | 'volume' | 'tenure'
  milestoneValue  Int         // e.g., 50 shipments, $5000 spend
  
  // Details
  description     String
  bonusAmount     Float
  
  // Status
  status          String      @default("achieved") // 'achieved' | 'claimed' | 'expired'
  achievedDate    DateTime    @default(now())
  claimedDate     DateTime?
  
  // Relations
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@index([customerId])
  @@index([type])
}

// ============================================================================
// PROMOTIONAL BONUS MODEL
// ============================================================================

model PromotionalBonus {
  id              String      @id @default(cuid())
  promotionCode   String      @unique
  
  // Campaign details
  name            String
  description     String?
  category        String      // 'seasonal' | 'flash' | 'birthday' | 'loyalty'
  
  // Bonus
  bonusAmount     Float?
  bonusPercent    Float?      // For percentage-based bonuses
  pointsMultiplier Float?     // For point multiplier bonuses
  
  // Eligibility
  targetAudience  String?     // JSON conditions
  minSpend        Float?
  maxRedemptions  Int?
  redeemptionsUsed Int        @default(0)
  
  // Dates
  startDate       DateTime
  endDate         DateTime
  createdDate     DateTime    @default(now())
  
  // Status
  active          Boolean     @default(true)
  
  @@index([promotionCode])
  @@index([active])
}

// ============================================================================
// BONUS REDEMPTION HISTORY MODEL
// ============================================================================

model BonusRedemption {
  id              String      @id @default(cuid())
  customerId      String
  
  // Bonus info
  bonusAmount     Float
  redemptionMethod String      // 'accountCredit' | 'freeShipment' | 'discountCode' | 'cashback'
  redemptionValue Float        // Value after conversion
  
  // Details
  reason          String?
  reference       String?      // Link to specific transaction
  
  // Status
  status          String      @default("completed") // 'pending' | 'processing' | 'completed' | 'failed'
  
  // Dates
  redeemedDate    DateTime    @default(now())
  processedDate   DateTime?
  
  // Relations
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@index([customerId])
  @@index([status])
  @@index([redeemedDate])
}

// ============================================================================
// BONUS AUDIT LOG MODEL
// ============================================================================

model BonusAuditLog {
  id              String      @id @default(cuid())
  customerId      String?
  action          String      // 'points_earned' | 'bonus_awarded' | 'tier_upgraded' | 'redemption_claimed'
  
  // Details
  details         String      // JSON with full details
  amount          Float?
  affectedTier    String?
  status          String      @default("recorded")
  
  // System
  ipAddress       String?
  userAgent       String?
  timestamp       DateTime    @default(now())
  
  @@index([customerId])
  @@index([action])
  @@index([timestamp])
}

// ============================================================================
// EXTENSION TO EXISTING CUSTOMER MODEL
// ============================================================================

// Add these fields to your existing Customer model:

extension Customer {
  // Loyalty fields
  loyaltyTierId   String?
  loyaltyTier     LoyaltyTier?
  
  // Referral fields
  referralsAsReferrer ReferralProgram[] @relation("referrer")
  referralsAsReferred ReferralProgram[] @relation("referred")
  
  // Milestone fields
  milestones      MilestoneAchievement[]
  
  // Redemption fields
  redemptions     BonusRedemption[]
}

// ============================================================================
// EXTENSION TO EXISTING DRIVER MODEL
// ============================================================================

extension Driver {
  // Performance tracking
  performance     DriverPerformance?
  performanceMetrics String? // JSON with historical metrics
}
