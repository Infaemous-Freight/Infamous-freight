# Local frontend (web) environment variables
# Backend-only secrets (DATABASE_URL, REDIS_URL, STRIPE_SECRET_KEY, TWILIO_AUTH_TOKEN, AI_API_KEY, etc.)
# should be defined in an API-specific env file (for example: api/.env.local) and not in frontend builds.
# Base URL for the API used by the Next.js frontend
# Standalone API (default: API_PORT=4000)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Docker Compose API (internal default: API_PORT=3001)
# NEXT_PUBLIC_API_URL=http://localhost:3001/api
