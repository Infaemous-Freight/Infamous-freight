{
  "buildCommand": "pnpm install && pnpm --filter web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':(exclude)node_modules' ':(exclude).next' ':(exclude)apps/api' ':(exclude)apps/mobile' ':(exclude)apps/ai'",
  "env": {
    "NODE_ENV": "production"
  }
}
