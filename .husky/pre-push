#!/usr/bin/env sh
husky_sh="$(dirname -- "$0")/_/husky.sh"
if [ -f "$husky_sh" ]; then
  # shellcheck disable=SC1090
  . "$husky_sh"
else
  echo "husky pre-push: missing helper script at $husky_sh"
  echo "Please run 'pnpm run hooks:install' to (re)install Husky hooks."
  exit 1
fi

set -eu

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

echo "==> husky pre-push: Infamous Freight"

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required but not installed."
  exit 1
fi

echo "==> Running typecheck"
pnpm typecheck

echo "==> Running tests"
pnpm test -- --runInBand

echo "==> Running build"
pnpm build

echo "✅ husky pre-push passed"
